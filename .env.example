# Core app configuration
NODE_ENV="development"
# Local MongoDB example:
DATABASE_URL="mongodb://localhost:27017/parseforge"
# Hosted MongoDB example:
# DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/parseforge"
JWT_SECRET_TOKEN="replace-with-at-least-32-random-characters"
PORT=4022
# Optional comma-separated browser origins allowed to call the API.
# Leave empty for same-origin deployments.
ALLOWED_ORIGINS=""

# Optional bootstrap admin user
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_FIRST_NAME="ParseForge"
BOOTSTRAP_ADMIN_LAST_NAME="Admin"
BOOTSTRAP_ADMIN_EMAIL="admin@parseforge.dev"
BOOTSTRAP_ADMIN_PASSWORD=""
BOOTSTRAP_ADMIN_COMPANY="ParseForge"
BOOTSTRAP_ADMIN_USE_CASE="platform-admin"
BOOTSTRAP_ADMIN_PLAN="enterprise"

# Optional bootstrap developer test user
BOOTSTRAP_TEST_USER_ENABLED=false
BOOTSTRAP_TEST_USER_FIRST_NAME="Test"
BOOTSTRAP_TEST_USER_LAST_NAME="Developer"
BOOTSTRAP_TEST_USER_EMAIL="tester@parseforge.dev"
BOOTSTRAP_TEST_USER_PASSWORD=""
BOOTSTRAP_TEST_USER_COMPANY="ParseForge QA"
BOOTSTRAP_TEST_USER_USE_CASE="login-testing"
BOOTSTRAP_TEST_USER_PLAN="starter"
